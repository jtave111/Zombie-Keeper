<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="content-pad" spacing="14" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.manager.Zombie_Keeper.ui.controller.localNetwork.NetworkSessionUIController">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="panel-title" text="NETWORK SESSIONS" style="-fx-font-size: 11px;">
            <HBox.margin><Insets right="20"/></HBox.margin>
        </Label>
        
        <fx:define>
            <ToggleGroup fx:id="networkTabsGroup"/>
        </fx:define>
        <ToggleButton fx:id="tabMap" text="TOPOLOGY MAP" toggleGroup="$networkTabsGroup" 
                      selected="true" styleClass="ag-filter" onAction="#switchTab"/>
        <ToggleButton fx:id="tabScanner" text="SCANNER MANAGER" toggleGroup="$networkTabsGroup" 
                      styleClass="ag-filter" onAction="#switchTab"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="netInfo" styleClass="net-info" text="Last scan: --:--:-- UTC" />
    </HBox>

    <StackPane fx:id="networkContentStack" VBox.vgrow="ALWAYS">
        
        <HBox fx:id="viewTopology" spacing="14" alignment="TOP_LEFT">
            
            <VBox styleClass="panel" minWidth="200" maxWidth="200">
                <HBox styleClass="panel-head" alignment="CENTER_LEFT">
                    <Label styleClass="panel-title" text="SESSIONS HISTORY" />
                </HBox>
                <ListView fx:id="sessionListView" styleClass="node-list" VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <StackPane styleClass="node-map" minHeight="250" maxHeight="250">
                    <Label styleClass="map-tag" text="VISUAL TOPOLOGY" StackPane.alignment="TOP_LEFT">
                        <StackPane.margin><Insets top="10" left="12"/></StackPane.margin>
                    </Label>
                    <Canvas fx:id="networkCanvas" width="500" height="230" />
                </StackPane>

                <VBox styleClass="panel" VBox.vgrow="ALWAYS">
                    <HBox styleClass="panel-head" alignment="CENTER_LEFT">
                        <Label styleClass="panel-title" text="DISCOVERED NODES" />
                    </HBox>
                    <TableView fx:id="nodeTableView" styleClass="zk-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNodeIpv4" text="IPv4 ADDRESS" prefWidth="130" />
                            <TableColumn fx:id="colNodeMac"  text="MAC ADDRESS"  prefWidth="160" />
                            <TableColumn fx:id="colNodeOs"   text="OS / DEVICE"  prefWidth="120" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>

            <VBox styleClass="panel" minWidth="250" maxWidth="250">
                <HBox styleClass="panel-head" alignment="CENTER_LEFT">
                    <Label styleClass="panel-title" text="NODE DETAILS" />
                </HBox>
                <TextArea fx:id="nodeDetailsArea" editable="false" wrapText="true" 
          VBox.vgrow="ALWAYS" 
          style="-fx-control-inner-background: #16161a; -fx-text-fill: #10b981; -fx-font-family: 'JetBrains Mono', monospace; -fx-background-color: transparent; -fx-border-color: #2b2b36;" />
            </VBox>

        </HBox>

        <VBox fx:id="viewScannerManager" styleClass="panel" visible="false" managed="false" alignment="CENTER" spacing="20">
            <Label styleClass="ph-icon" text="⟳" />
            <Label styleClass="ph-title" text="TACTICAL SCANNER UPLINK" style="-fx-font-size: 14px;"/>
            <Label styleClass="ph-sub" text="Configure the SpiderNETx module to probe the current network session." />
            
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnRunScan" styleClass="scan-btn" text="▶ LAUNCH LOCAL SCAN" onAction="#runFullScan"/>
                <Button styleClass="act-btn" text="⚙ ADVANCED OPTIONS" />
            </HBox>
        </VBox>

    </StackPane>

</VBox>