<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<HBox styleClass="root-pane"
      stylesheets="/static/css/login.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.manager.Zombie_Keeper.ui.controller.auth.AuthUiController">

    <VBox styleClass="col-left" minWidth="420" maxWidth="420" spacing="0"
          style="-fx-background-color: radial-gradient(center 30% 50%, radius 70%, rgba(140,5,18,0.10) 0%, transparent 60%);">

        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <Label styleClass="status-offline" text="C2 INFRASTRUCTURE" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="status-channel" text="SECURE CHANNEL" />
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </HBox>

        <VBox styleClass="glass-panel" spacing="0">

            <VBox alignment="CENTER" spacing="8">
                <StackPane styleClass="brand-icon" minWidth="60" maxWidth="60" minHeight="60" maxHeight="60">
                    <Label styleClass="brand-icon-glyph" text="☣" />
                </StackPane>
                <Label styleClass="brand-name" text="ZOMBIE KEEPER" />
                <Label styleClass="brand-sub"  text="Test version V0001" />
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </VBox>

            <HBox fx:id="errorBox" styleClass="error-box" alignment="CENTER_LEFT"
                  spacing="8" visible="false" managed="false">
                <Label fx:id="errorText" styleClass="error-text"
                       text="Invalid credentials. Access denied." />
                <VBox.margin><Insets bottom="14"/></VBox.margin>
            </HBox>

            <VBox spacing="14">

                <VBox spacing="5">
                    <Label styleClass="field-label" text="USER" />
                    <TextField fx:id="txtUsername"
                               styleClass="input-field"
                               promptText="username" />
                </VBox>

                <VBox spacing="5">
                    <Label styleClass="field-label" text="PASSWORD" />
                    <PasswordField fx:id="txtPassword"
                                   styleClass="input-field"
                                   promptText="••••••••" />
                </VBox>

                <VBox spacing="5">
                    <Label styleClass="field-label" text="ROLE" />
                    <HBox spacing="8">
                        <ToggleButton fx:id="btnOperator"
                                      styleClass="role-btn"
                                      text="Operator"
                                      selected="true"
                                      HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <toggleGroup>
                                <ToggleGroup fx:id="roleGroup" />
                            </toggleGroup>
                        </ToggleButton>
                        <ToggleButton fx:id="btnAdmin"
                                      styleClass="role-btn"
                                      text="Admin"
                                      toggleGroup="$roleGroup"
                                      HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </HBox>
                </VBox>

                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </VBox>

            <Button fx:id="btnConnect"
                    styleClass="btn-connect"
                    text="▶  INITIALIZE SWARM UPLINK"
                    maxWidth="Infinity"
                    onAction="#performLogin">
                <VBox.margin><Insets top="14" bottom="18"/></VBox.margin>
            </Button>

            <VBox styleClass="terminal-box">

                <HBox styleClass="terminal-header" alignment="CENTER_LEFT">
                    <HBox spacing="5" alignment="CENTER">
                        <StackPane styleClass="t-dot t-dot-red"
                                   minWidth="8" maxWidth="8" minHeight="8" maxHeight="8"/>
                        <StackPane styleClass="t-dot"
                                   minWidth="8" maxWidth="8" minHeight="8" maxHeight="8"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="terminal-title" text="SESSION LOGS" />
                </HBox>

                <ScrollPane styleClass="terminal-scroll"
                            fitToWidth="true"
                            hbarPolicy="NEVER" vbarPolicy="NEVER"
                            minHeight="90" maxHeight="90">
                    <VBox fx:id="terminalOutput" styleClass="terminal-body"
                          spacing="0" alignment="BOTTOM_LEFT">
                        <Label styleClass="t-line"
                               text="SYS  Awaiting operator credentials..._"
                               opacity="0.55"/>
                    </VBox>
                </ScrollPane>

            </VBox>

        </VBox>
    </VBox>
    <StackPane styleClass="col-right" HBox.hgrow="ALWAYS">

        <Rectangle styleClass="col-right-divider"
                   width="1" height="200"
                   StackPane.alignment="CENTER_LEFT" />

        <VBox alignment="CENTER" spacing="0" maxWidth="340">

            <Label styleClass="quote-skull" text="☣">
                <VBox.margin><Insets bottom="28"/></VBox.margin>
            </Label>

            <Label styleClass="quote-mark" text="&#8220;"
                   StackPane.alignment="TOP_LEFT" />

            <VBox alignment="CENTER" spacing="4">
                <Label styleClass="quote-line-dim"  text="The puppeteer is" />
                <Label styleClass="quote-line-hl"   text="invisible." />
                <Label styleClass="quote-spacer"    text="" minHeight="10" />
                <Label styleClass="quote-line-dim"  text="The puppet believes" />
                <Label styleClass="quote-line-dim"  text="it" />
                <Label styleClass="quote-line-hl"   text="dances alone." />
                <VBox.margin><Insets bottom="0"/></VBox.margin>
            </VBox>

            <StackPane styleClass="quote-divider"
                       minHeight="1" maxHeight="1" minWidth="32" maxWidth="32">
                <VBox.margin><Insets top="22" bottom="18"/></VBox.margin>
            </StackPane>

            <Label styleClass="quote-attr" text="ZOMBIE KEEPER — C2 FRAMEWORK" />

        </VBox>

        <Label styleClass="watermark"
               text="AUTHORIZED ACCESS ONLY — ZK INFRASTRUCTURE"
               StackPane.alignment="BOTTOM_CENTER">
            <StackPane.margin><Insets bottom="18"/></StackPane.margin>
        </Label>

    </StackPane>

</HBox>