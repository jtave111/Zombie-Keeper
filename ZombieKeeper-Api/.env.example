# ============================================
# ZOMBIE KEEPER - ENVIRONMENT VARIABLES
# ============================================
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env nunca deve ser commitado no repositório.

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your-database-name
DB_USERNAME=root
DB_PASSWORD=your-db-password

# ============================================
# JWT CONFIGURATION
# ============================================
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================
# SERVER
# ============================================
SERVER_PORT=8080
SERVER_ADDRESS=0.0.0.0

# ============================================
# SPRING PROFILES
# ============================================
SPRING_PROFILES_ACTIVE=dev

# ============================================
# CORS (API)
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# ============================================
# FILE UPLOAD (Loot)
# ============================================
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=10485760
FILE_MAX_REQUEST_SIZE=10485760

# ============================================
# LIQUIBASE
# ============================================
LIQUIBASE_ENABLED=true
LIQUIBASE_DROP_FIRST=false

# ============================================
# LOGGING
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
LOGGING_FILE_PATH=./logs
LOGGING_FILE_NAME=zombie-keeper.log

# ============================================
# REDIS (opcional - cache de sessões)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================
# C2 CONFIGURATION
# ============================================
C2_AGENT_TIMEOUT=300000
C2_HEARTBEAT_INTERVAL=60000
C2_MAX_AGENTS=1000

# ============================================
# ADMIN INITIAL USER
# Usado pelo DataInitializer ao subir a aplicação pela primeira vez.
# Deixe em branco para pular a criação automática do admin.
# ============================================
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
ADMIN_NAME=your-admin-display-name
ADMIN_EMAIL=admin@zombiekeeper.local

# ============================================
# ENCRYPTION
# ============================================
ENCRYPTION_KEY=your-encryption-key-here-32-chars-min
ENCRYPTION_ALGORITHM=AES

# ============================================
# EXTERNAL APIS (opcional)
# ============================================
# NVD: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-api-key
# Shodan: https://account.shodan.io
SHODAN_API_KEY=your-shodan-api-key
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
