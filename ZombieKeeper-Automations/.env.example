# ─────────────────────────────────────────────────────────────────────────────
# ZombieKeeper Automations — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# URL base da API do ZombieKeeper (Spring Boot)
ZK_API_URL=http://localhost:8080

# Credenciais de acesso à API
ZK_USERNAME=admin
ZK_PASSWORD=your-password-here
